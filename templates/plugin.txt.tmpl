# OpenC3 COSMOS ROS2 Plugin — scaffolded from openc3-cosmos-ros2
#
# Bridges to ROS2 via rosbridge_suite's WebSocket transport. On the ROS2 host:
#     sudo apt install ros-${ROS_DISTRO}-rosbridge-suite
#     ros2 launch rosbridge_server rosbridge_websocket_launch.xml
#
# Topic subscriptions are driven by lib/topics.txt (one topic per line).

VARIABLE ros2_target_name __TARGET__
VARIABLE_DESCRIPTION "COSMOS target name for this ROS2 robot"

VARIABLE rosbridge_host host.docker.internal
VARIABLE_DESCRIPTION "Host running rosbridge_websocket (laptop / robot)"

VARIABLE rosbridge_port 9090
VARIABLE_DESCRIPTION "rosbridge_websocket port (default 9090)"

VARIABLE throttle_rate 100
VARIABLE_DESCRIPTION "Min milliseconds between messages per topic (0 = no throttle, 100 = 10Hz)"

TARGET __TARGET__ <%= ros2_target_name %>

INTERFACE <%= ros2_target_name %>_INT rosbridge_websocket_interface.py <%= rosbridge_host %> <%= rosbridge_port %> 10.0
  MAP_TARGET <%= ros2_target_name %>
  # Send `subscribe` ops on connect for every topic in lib/topics.txt.
  PROTOCOL READ_WRITE rosbridge_subscribe_protocol.py lib/topics.txt <%= throttle_rate %>
